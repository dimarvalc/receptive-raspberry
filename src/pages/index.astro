---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all 5 collection pipelines to calculate live dashboard analytics
const coins = await getCollection('coins');
const banknotes = await getCollection('banknotes');
const cachets = await getCollection('cachets'); // Philatelic items
const stocks = await getCollection('stocks');   // Stocks & Bonds Certificates
const restorations = await getCollection('restorations'); // AI Restorations Projects

// Calculate the grand total of cataloged items
const totalAssets = coins.length + banknotes.length + cachets.length + stocks.length + restorations.length;
---

<Layout title="TSL Digital Studio | Cultural Archives & Digital Preservation">
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-slate-900 text-slate-100 flex flex-col justify-center py-16 px-6">
    
    <!-- Hero Branding Header -->
    <header class="max-w-3xl mx-auto text-center mb-16 select-none">
      <div class="inline-block bg-blue-500/10 border border-blue-500/20 text-blue-400 font-mono text-xs font-bold tracking-widest px-4 py-1.5 rounded-full uppercase mb-4 shadow-sm animate-pulse">
        Live Project Preservation Ledger
      </div>
      <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl uppercase bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-200 to-slate-400">
        TSL Digital Studio
      </h1>
      <p class="text-slate-400 font-medium text-lg sm:text-xl mt-4 max-w-xl mx-auto leading-relaxed">
        Welcome to my centralized archival pipeline. Explore my historical collection registries and digital restoration labs below.
      </p>
    </header>

    <!-- Balanced Dynamic Grid Matrix Workspace Layout -->
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full items-stretch">
      
      <!-- PORTAL 1: PHILATELIC ARCHIVE -->
      <a href="/cachets/1" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-blue-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/0 via-blue-600/0 to-blue-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            ✉️
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-blue-400 transition-colors duration-200">Philatelic Archive</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Browse through my complete catalog of historical custom cachet envelope designs. Features high-resolution digital lightbox zoom windows and file download tracking.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-blue-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Enter Catalog Database <span>→</span>
        </div>
      </a>

      <!-- PORTAL 2: WORLD BANKNOTES VAULT -->
      <a href="/banknotes" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-emerald-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/0 via-emerald-600/0 to-emerald-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            💵
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-emerald-400 transition-colors duration-200">Banknotes Vault</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Review global paper currencies categorized by country, face values, and alphanumeric variety catalog numbers mapping back to standard museum identifiers.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-emerald-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Unlock Currency Vault <span>→</span>
        </div>
      </a>

      <!-- PORTAL 3: HISTORICAL STOCKS LEDGER -->
      <a href="/stocks" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-amber-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-amber-600/0 via-amber-600/0 to-amber-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            📜
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-amber-400 transition-colors duration-200">Stocks & Bonds Ledger</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Explore unique scripophily certificates cataloged by shared corporate volume tiers, border engraving variants, and unique historical serial numbers.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-amber-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Review Certificate Ledger <span>→</span>
        </div>
      </a>

      <!-- PORTAL 4: NUMISMATIC COINS VAULT -->
      <a href="/coins" class="group relative lg:col-start-1 bg-slate-800/40 border border-slate-700/50 hover:border-yellow-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-yellow-600/0 via-yellow-600/0 to-yellow-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            🪙
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-yellow-400 transition-colors duration-200">Coins Vault</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Step into the numismatic coin collection. Track historical strike dates, precise metallic compositions, grading scales, and obverse/reverse detailed photography.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-yellow-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Open Numismatic Vault <span>→</span>
        </div>
      </a>

      <!-- PORTAL 5: AI PHOTO RESTORATION LAB -->
      <a href="/restorations" class="group relative lg:col-start-2 bg-slate-800/40 border border-slate-700/50 hover:border-indigo-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/0 via-indigo-600/0 to-indigo-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            🖼️
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-indigo-400 transition-colors duration-200">AI Photo Restoration Lab</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Interact with our split-screen photo workspace. Move the custom drag handles back and forth to reveal pixel-by-pixel comparisons on restored graphics.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-indigo-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Open Slider Studio <span>→</span>
        </div>
      </a>

      <!-- 6th Card Slot: Archival Processing Metrics Dashboard -->
      <div class="bg-slate-800/40 border border-slate-700/50 p-8 rounded-2xl shadow-xl backdrop-blur-sm flex flex-col justify-between group hover:border-purple-500/30 transition-all duration-300">
        <div>
          <!-- Thematic Badging -->
          <div class="flex items-center gap-2 mb-4">
            <span class="inline-block w-2 h-2 rounded-full bg-purple-400 animate-pulse"></span>
            <span class="text-[10px] font-black tracking-widest uppercase bg-purple-500/10 text-purple-400 px-2.5 py-1 rounded-full border border-purple-500/20">
              System Status: Operational
            </span>
          </div>

          <!-- Title and Subtitle Header -->
          <h3 class="text-xl font-bold text-white tracking-tight mb-2">Archival Processing Metrics</h3>
          <p class="text-slate-400 text-xs leading-relaxed mb-6">
            Live structural analytics monitoring data integrity, database ledger volume counts, and asset layer distribution channels.
          </p>

          <!-- Refactored 6-Item Analytical Counter Grid Matrix -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
            <!-- 1. Total Assets Master Count -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl col-span-2 sm:col-span-3">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Total Vault Assets (Combined Ledger)</p>
              <p class="text-3xl font-black text-white font-mono tracking-tight">{totalAssets}</p>
            </div>

            <!-- 2. Coins Vault -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Coins Indexed</p>
              <p class="text-xl font-black text-yellow-400 font-mono tracking-tight">{coins.length}</p>
            </div>

            <!-- 3. Banknotes Vault -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Notes Cataloged</p>
              <p class="text-xl font-black text-green-400 font-mono tracking-tight">{banknotes.length}</p>
            </div>

            <!-- 4. Philatelic Cachets -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Cachets Tracked</p>
              <p class="text-xl font-black text-blue-400 font-mono tracking-tight">{cachets.length}</p>
            </div>

            <!-- 5. Stocks & Bonds -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Scripophily Certs</p>
              <p class="text-xl font-black text-orange-400 font-mono tracking-tight">{stocks.length}</p>
            </div>

            <!-- 6. AI Photo Restoration Lab -->
            <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-xl col-span-2 sm:col-span-1">
              <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">AI Restorations</p>
              <p class="text-xl font-black text-emerald-400 font-mono tracking-tight">{restorations.length}</p>
            </div>
          </div>
        </div>

        <!-- Action Prompt Linking to Code Base Repository -->
        <div class="border-t border-slate-700/40 pt-4 mt-auto">
          <a 
            href="https://github.com" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="inline-flex items-center text-[10px] font-bold text-purple-400 hover:text-purple-300 transition-colors uppercase tracking-widest gap-1 group-hover:translate-x-0.5 duration-200"
          >
            Review Ledger Infrastructure &rarr;
          </a>
        </div>
      </div>


    </div>

    <!-- Small Professional System Footer -->
    <footer class="max-w-md mx-auto text-center mt-20 text-[10px] font-bold text-slate-600 uppercase tracking-widest select-none">
      Static Architecture Driven by Astro & Vercel
    </footer>

  </main>
</Layout>


