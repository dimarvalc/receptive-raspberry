---
import '../styles/global.css';
// Accept dynamic titles passed down from individual archive pages
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title || "TSL Digital Studio"}</title>
	</head>
	<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">
		
		<!-- 🚀 GLOBAL NAVIGATION HEADER BAR -->
		<header class="w-full bg-slate-900/80 border-b border-slate-800 backdrop-blur-md sticky top-0 z-50 transition-all duration-200">
			<div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
				
				<!-- Left Side: Brand Logo Link -->
				<a href="/" class="text-sm font-black tracking-wider uppercase text-white hover:text-blue-400 transition-colors duration-150 flex items-center gap-2 select-none">
					<span class="text-base">🏛️</span> TSL Studio
				</a>

				<!-- Right Side: Unified Navigation Links -->
				<nav class="flex items-center gap-1 sm:gap-4 font-mono text-[11px] font-bold uppercase tracking-wider">
					<a href="/cachets/1" class="px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800/60 transition-all duration-150">
						✉️ Cachets
					</a>
					<a href="/banknotes" class="px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800/60 transition-all duration-150">
						💵 Notes
					</a>
					<a href="/stocks" class="px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800/60 transition-all duration-150">
						📜 Stocks
					</a>
					<a href="/restorations" class="px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800/60 transition-all duration-150">
						🖼️ Lab
					</a>
				</nav>

			</div>
		</header>

		<!-- The page content fills the blank slot space right below the header -->
		<div class="flex-grow">
			<slot />
		</div>

	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
