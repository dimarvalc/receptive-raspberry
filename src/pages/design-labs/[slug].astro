---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. Tell Astro to generate a unique standalone page for each markdown entry in designLabs
export async function getStaticPaths() {
  const labEntries = await getCollection('designLabs');
  return labEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Extract entry properties and render the Markdown content body
const { entry } = Astro.props;
const { Content } = await render(entry);

// Format date elegantly for display
const formattedDate = entry.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={`${entry.data.title} | Design Laboratory`}>
  <main class="max-w-4xl mx-auto px-6 py-12 min-h-screen flex flex-col">
    
    <nav class="mb-8">
      <a href="/cachets/1" class="text-xs font-mono font-bold text-slate-500 hover:text-blue-400 transition-colors uppercase tracking-wider flex items-center gap-2">
        &larr; Return to Cachets Archive
      </a>
    </nav>

    <header class="border-b border-slate-800 pb-8 mb-8">
      <div class="inline-block bg-purple-500/10 border border-purple-500/20 text-purple-400 font-mono text-[10px] font-bold tracking-widest px-3 py-1 rounded-md uppercase mb-4 shadow-sm">
        🔬 Production Workspace & Prompt Log
      </div>
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl uppercase">
        {entry.data.title}
      </h1>
      <div class="mt-3 flex items-center gap-4 text-xs font-mono text-slate-400">
        <p>Published: <span class="text-slate-300">{formattedDate}</span></p>
        <p>&bull;</p>
        <p>Event ID: <span class="text-purple-400">{entry.data.eventKey}</span></p>
      </div>
    </header>

    <article class="prose prose-invert prose-slate max-w-none text-slate-300 leading-relaxed text-sm antialiased font-normal 
      prose-headings:uppercase prose-headings:font-black prose-headings:tracking-tight
      prose-a:text-blue-400 hover:prose-a:text-blue-300
      prose-blockquote:border-l-purple-500 prose-blockquote:bg-purple-950/20 prose-blockquote:px-4 prose-blockquote:py-1 prose-blockquote:rounded-r-lg prose-blockquote:text-slate-300 prose-blockquote:not-italic
      prose-img:rounded-xl prose-img:border prose-img:border-slate-800 prose-img:shadow-md">
      
      <Content />
      
    </article>

    <footer class="mt-16 pt-6 border-t border-slate-800 text-center font-mono text-[10px] text-slate-500 tracking-wider">
      TSL Studio Ledger Infrastructure &bull; End of Production Entry
    </footer>

  </main>
</Layout>