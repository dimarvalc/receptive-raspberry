---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TSL Digital Studio | Numismatics, Philately, Scripophily, Notaphily & AI Restoration">
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-slate-900 text-slate-100 flex flex-col justify-center py-16 px-6">
    
    <!-- Hero Branding Header -->
    <header class="max-w-3xl mx-auto text-center mb-16 select-none">
      <div class="inline-block bg-blue-500/10 border border-blue-500/20 text-blue-400 font-mono text-xs font-bold tracking-widest px-4 py-1.5 rounded-full uppercase mb-4 shadow-sm animate-pulse">
        Now Live Workspace Pipeline
      </div>
      <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl uppercase bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-200 to-slate-400">
        TSL Digital Studio
      </h1>
      <p class="text-slate-400 font-medium text-lg sm:text-xl mt-4 max-w-xl mx-auto leading-relaxed">
        Welcome to my centralized digital ledger archive. Explore my separate creative tracking database platforms below.
      </p>
    </header>

    <!-- Symmetric 4-Card Creative Dashboard Portals -->
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
      
      <!-- PORTAL 1: PHILATELIC ARCHIVE -->
      <a href="/cachets/1" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-blue-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/0 via-blue-600/0 to-blue-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            ✉️
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-blue-400 transition-colors duration-200">Philatelic Cover Archive</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Browse through my complete, automated database of historical custom cachet envelope designs. Features a native high-resolution digital lightbox zoom viewer and file download tracking system.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-blue-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Enter Catalog Database <span>→</span>
        </div>
      </a>

      <!-- PORTAL 2: AI RESTORATION LAB -->
      <a href="/restorations" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-emerald-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/0 via-emerald-600/0 to-emerald-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            🖼️
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-emerald-400 transition-colors duration-200">AI Photo Restoration Lab</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Step into the interactive comparison studio. Witness real-time pixel transformations between damaged historical portraits, documents, and my digitally restored canvas layers.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-emerald-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Open Slider Studio <span>→</span>
        </div>
      </a>

      <!-- PORTAL 3: BANKNOTES VAULT -->
      <a href="/banknotes" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-emerald-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/0 via-emerald-600/0 to-emerald-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            💵
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-emerald-400 transition-colors duration-200">World Banknotes Vault</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Review world paper currencies categorized by country, face values, issuance years, and alphanumeric catalog numbers mapping right back to standard museum identifiers.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-emerald-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Unlock Currency Vault <span>→</span>
        </div>
      </a>

      <!-- PORTAL 4: STOCKS LEDGER -->
      <a href="/stocks" class="group relative bg-slate-800/40 border border-slate-700/50 hover:border-amber-500/40 p-8 rounded-2xl shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-amber-600/0 via-amber-600/0 to-amber-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mb-6 group-hover:scale-110 transition-transform duration-200">
            📜
          </div>
          <h2 class="text-2xl font-black text-white tracking-tight mb-2 group-hover:text-amber-400 transition-colors duration-200">Historical Stocks Ledger</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Explore scripophily certificates cataloged by shared volume tiers, border print coloration variants, unique serial identifiers, and corporate cancellation dates.
          </p>
        </div>
        <div class="relative z-10 flex items-center text-xs font-bold font-mono text-amber-400 uppercase tracking-wider gap-1.5 group-hover:gap-3 transition-all duration-200">
          Review Certificate Ledger <span>→</span>
        </div>
      </a>

    </div>

    <!-- Small Professional System Footer -->
    <footer class="max-w-md mx-auto text-center mt-20 text-[10px] font-bold text-slate-600 uppercase tracking-widest select-none">
      Static Architecture Driven by Astro & Vercel
    </footer>

  </main>
</Layout>

