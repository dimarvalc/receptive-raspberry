---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

// 1. INITIALIZE IMAGE GLOB FIRST (Moved up here so it's ready instantly!)
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/cachets/*.webp');

// 2. Tell Astro to slice your 232+ collection into pages of 10 items each
export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('cachets');
  const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  
  return paginate(sortedPosts, { pageSize: 10 }); // Change 10 to whatever number you prefer!
}

// 3. Grab the specific page data for the current screen
const { page } = Astro.props;

// 4. Process the text content AND resolve perfect image paths ahead of time
const renderedPosts = await Promise.all(
  page.data.map(async (postItem) => {
    const { Content } = await render(postItem);
    
    // Construct the dynamic path keys
    const frontKey = `/src/assets/cachets/${postItem.data.imageStem}-front-${postItem.data.envelopeSize}.webp`;
    const backKey = `/src/assets/cachets/${postItem.data.imageStem}-back-${postItem.data.envelopeSize}.webp`;
    
    // 🎯 CLEAN & MINIMAL: Just track one standard cancel string and one simulated string!
    const standardCancelKey = `/src/assets/cachets/${postItem.data.imageStem}-cancel-${postItem.data.envelopeSize}.webp`;
    const simulatedKey = `/src/assets/cachets/${postItem.data.imageStem}-simulated-${postItem.data.envelopeSize}.webp`;

    // Resolve the real static assets natively 
    const frontAsset = allImages[frontKey] ? await allImages[frontKey]() : null;
    const backAsset = allImages[backKey] ? await allImages[backKey]() : null;
    
    // 🎯 STREAMLINED LOOKUP: Pulls -simulated if flagged true, otherwise pulls the standard -cancel file
    const cancelAsset = postItem.data.isSimulated
      ? (allImages[simulatedKey] ? await allImages[simulatedKey]() : null)
      : (allImages[standardCancelKey] ? await allImages[standardCancelKey]() : null);


    return { 
      post: postItem, 
      Content,
      frontSrc: frontAsset?.default?.src || '',
      backSrc: backAsset?.default?.src || '',
      cancelSrc: cancelAsset?.default?.src || '',
      // 🎯 FIXED: Explicitly passes the missing dimension metrics down!
      frontW: frontAsset?.default?.width || 1800,
      frontH: frontAsset?.default?.height || 1000,
      backW: backAsset?.default?.width || 1800,
      backH: backAsset?.default?.height || 1000,
      cancelW: cancelAsset?.default?.width || 1800,
      cancelH: cancelAsset?.default?.height || 1000,
    };
  })
);


---

<Layout title={`Cachet Archive - Page ${page.currentPage}`}>
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-slate-900 text-slate-100 py-12 px-6">
    
    <header class="max-w-6xl mx-auto mb-16 text-center">
      <a href="/" class="text-xs font-bold text-blue-400 hover:text-blue-300 transition duration-150 uppercase tracking-widest block mb-4">← Back to Dashboard Overview</a>
      <h1 class="text-4xl font-black text-white tracking-tight sm:text-5xl">Philatelic Cover Master Archive</h1>
      <p class="text-slate-400 font-medium mt-3">Viewing catalog entries {page.start + 1} through {page.end + 1} of your historical ledger database.</p>
    </header>

    <!-- The Grid Loop Layout Grid (Explicit matching trigger ID) -->
    <div class="max-w-7xl mx-auto flex flex-col gap-16" id="cachet-archive-grid">
      {renderedPosts.map(({ post, Content, frontSrc, backSrc, cancelSrc, frontW, frontH, backW, backH, cancelW, cancelH }) => {
        
        const isC10 = post.data.envelopeSize === 'c10';
        const is9Bar = post.data.envelopeSize === '9bar';
        const isTall = post.data.envelopeSize === '5x7' || post.data.envelopeSize === 'a7';

        const aspectClass = 
          isC10 ? 'aspect-[2.3/1]' : 
          isTall ? 'aspect-[1.4/1]' : 
          is9Bar ? 'aspect-[1.52/1]' : 
          'aspect-[1.8/1]';

        return (
          <article class="bg-slate-800/40 border border-slate-700/50 p-8 rounded-2xl shadow-xl backdrop-blur-sm">
            
            <!-- Card Top Header Section -->
            <div class="flex flex-col md:flex-row justify-between items-center border-b border-slate-700/60 pb-4 mb-6 gap-2">
              <div>
                <span class="text-xs font-bold px-2.5 py-1 bg-blue-500/10 text-blue-400 rounded-full border border-blue-500/20 uppercase tracking-wider mr-2">
                  Size: {post.data.envelopeSize.toUpperCase()}
                </span>
                <span class="text-xs text-slate-400 font-mono">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })} • Sequence #{post.data.sequence}
                </span>
              </div>
              <h2 class="text-2xl font-black text-white tracking-tight">{post.data.title}</h2>
            </div>

            <!-- 3-Column Visual Presentation Grid Matrix (Light canvas backings to keep envelope transparency perfect) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              
              <!-- Front Canvas View -->
              <div class="flex flex-col justify-between">
                <div class={`bg-slate-900 border border-slate-700 p-3 rounded-xl flex items-center justify-center shadow-inner group hover:border-blue-500/50 transition-colors duration-150 ${aspectClass}`}>
                  {frontSrc ? (
                    <a href={frontSrc} data-pswp-width={frontW} data-pswp-height={frontH} target="_blank" title="Click to view full-size design" class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in">
                      <img src={frontSrc} alt="Front Design View" class="w-full h-auto max-h-full object-contain filter drop-shadow-md group-hover:scale-[1.01] transition-transform duration-150" />
                    </a>
                  ) : (
                    <div class="text-xs text-rose-500 font-mono">Front Image Missing</div>
                  )}
                </div>
                <p class="text-[10px] font-bold text-center text-slate-400 mt-2 tracking-widest uppercase">Front Design</p>
              </div>

              <!-- Back Canvas View -->
              <div class="flex flex-col justify-between">
                <div class={`bg-slate-900 border border-slate-700 p-3 rounded-xl flex items-center justify-center shadow-inner group hover:border-blue-500/50 transition-colors duration-150 ${aspectClass}`}>
                  {post.data.hasBack && backSrc ? (
                    <a href={backSrc} data-pswp-width={backW} data-pswp-height={backH} target="_blank" title="Click to view full-size design" class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in">
                      <img src={backSrc} alt="Back Layout View" class="w-full h-auto max-h-full object-contain filter drop-shadow-md group-hover:scale-[1.01] transition-transform duration-150" />
                    </a>
                  ) : (
                    <div class="text-xs text-slate-500 italic font-mono flex items-center justify-center h-full">No Content on Back</div>
                  )}
                </div>
                <p class="text-[10px] font-bold text-center text-slate-400 mt-2 tracking-widest uppercase">Back Layout</p>
              </div>

              <!-- Cancel Canvas View -->
              <div class="flex flex-col justify-between">
                <div class={`bg-slate-900 border border-slate-700 p-3 rounded-xl flex items-center justify-center shadow-inner group hover:border-blue-500/50 transition-colors duration-150 ${aspectClass}`}>
                  {/* 🎯 THE OVERRIDE RULE: Automatically opens the asset loader if hasCancel is true OR if isSimulated is true! */}
                  {(post.data.hasCancel || post.data.isSimulated) && cancelSrc ? (
                    <a href={cancelSrc} data-pswp-width={cancelW} data-pswp-height={cancelH} target="_blank" title="Click to view full-size design" class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in">
                      <img src={cancelSrc} alt={post.data.isSimulated ? "Simulated Postmark View" : "Official Pictorial Postmark View"} class="w-full h-auto max-h-full object-contain filter drop-shadow-md group-hover:scale-[1.01] transition-transform duration-150" />
                    </a>
                  ) : (
                    <div class="text-xs text-slate-500 italic font-mono flex items-center justify-center h-full">
                      {post.data.isSimulated ? "Simulated Cancel Asset Missing" : "Uncanceled"}
                    </div>
                  )}
                </div>
                {/* 🎯 DYNAMIC TEXT LABEL: Automatically toggles the column text heading between options! */}
                <p class="text-[10px] font-bold text-center text-blue-400 mt-2 tracking-widest uppercase">
                  {post.data.isSimulated ? "Simulated Postmark" : "Canceled Version"}
                </p>
              </div>


            </div>

            <!-- Content Area Text Segments with Custom Typography -->
            <div class="prose prose-invert prose-slate max-w-none border-t border-slate-700/60 pt-6 text-slate-300
              prose-headings:text-white prose-headings:font-black prose-headings:tracking-tight
              prose-p:leading-relaxed prose-p:text-slate-300
              prose-strong:text-blue-400 prose-strong:font-bold
              prose-ul:list-disc prose-ul:pl-5 prose-li:my-1">
              <Content />
            </div>

          </article>
        );
      })}
    </div>

    <!-- Pagination Navigation Controls -->
    <nav class="max-w-xl mx-auto flex items-center justify-between mt-16 font-medium font-mono text-sm">
      {page.url.prev ? <a href={page.url.prev} class="bg-slate-800 text-slate-200 border border-slate-700 px-5 py-2.5 rounded-xl shadow-md hover:bg-slate-700 transition duration-150">← Previous Page</a> : <span class="text-slate-600 border border-slate-800/80 px-5 py-2.5 rounded-xl cursor-not-allowed">← Previous Page</span>}
      <span class="text-slate-400">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next} class="bg-slate-800 text-slate-200 border border-slate-700 px-5 py-2.5 rounded-xl shadow-md hover:bg-slate-700 transition duration-150">Next Page →</a> : <span class="text-slate-600 border border-slate-800/80 px-5 py-2.5 rounded-xl cursor-not-allowed">Next Page →</span>}
    </nav>

  </main>
</Layout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#cachet-archive-grid',
    children: 'a.lightbox-trigger',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.95,
    padding: { top: 30, bottom: 30, left: 30, right: 30 }
  });

  lightbox.on('uiRegister', function() {
    lightbox.pswp.ui.registerElement({
      name: 'download-button',
      order: 8,
      isButton: true,
      tagName: 'a',
      html: '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 32 32" width="24" height="24"><path d="M23 14l-7 7-7-7h4V4h6v10h4zM4 26h24v2H4v-2z" fill="currentColor"/></svg>',
      onInit: (el, pswp) => {
        el.setAttribute('download', '');
        el.setAttribute('target', '_blank');
        el.setAttribute('title', 'Download High-Res Original');
        pswp.on('change', () => {
          el.href = pswp.currSlide.data.src;
        });
      }
    });
  });

  lightbox.init();
</script>




