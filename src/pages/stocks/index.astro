---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. Initialize image tracking specifically for stocks directory folder
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/stocks/*.webp');

// 2. Fetch all certificate logging records
const allStocks = await getCollection('stocks');

// 3. Sort records by date (Newest First) using Markdown frontmatter data
const sortedStocks = allStocks.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const renderedStocks = await Promise.all(
  sortedStocks.map(async (item) => {
    const { Content } = await render(item);
    
    // 🎯 Dynamically build front and back asset path match keys
    const frontKey = `/src/assets/stocks/${item.data.imageStem}-front.webp`;
    const backKey = `/src/assets/stocks/${item.data.imageStem}-back.webp`;

    const frontModule = allImages[frontKey] ? await allImages[frontKey]() : null;
    const backModule = allImages[backKey] ? await allImages[backKey]() : null;

    return {
      post: item,
      Content,
      frontSrc: frontModule?.default?.src || '',
      backSrc: backModule?.default?.src || '',
      frontW: frontModule?.default?.width || 1800,
      frontH: frontModule?.default?.height || 1200,
      backW: backModule?.default?.width || 1800,
      backH: backModule?.default?.height || 1200,
    };
  })
);
---

<Layout title="Historical Stocks & Bonds Ledger | Tomy's Digital Studio">
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-slate-900 text-slate-100 py-12 px-6">
    
    <header class="max-w-4xl mx-auto mb-16 text-center">
      <a href="/" class="text-xs font-bold text-amber-400 hover:text-amber-300 transition duration-150 uppercase tracking-widest block mb-4">← Back to Master Portfolio</a>
      <h1 class="text-4xl font-black text-white tracking-tight sm:text-5xl">Historical Stocks & Bonds Ledger</h1>
      <p class="text-slate-400 font-medium mt-3 max-w-2xl mx-auto">
        Scripophily registry tracking unique security asset certificates, printing variations, front endorsements, and reverse transfer assignments.
      </p>
    </header>

    <!-- Main Certificate Stack Layout Grid -->
    <div class="max-w-7xl mx-auto flex flex-col gap-12" id="stocks-archive-grid">
      {renderedStocks.map(({ post, Content, frontSrc, backSrc, frontW, frontH, backW, backH }) => (
        <article class="bg-slate-800/40 border border-slate-700/50 p-8 rounded-2xl shadow-xl backdrop-blur-sm grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          
          <!-- LEFT INFO COLUMN -->
          <div class="lg:col-span-4 flex flex-col justify-between h-full">
            <div>
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="text-[10px] font-black tracking-widest uppercase bg-amber-500/10 text-amber-400 px-2.5 py-1 rounded-full border border-amber-500/20">
                  {post.data.sharesCount}
                </span>
                <span class="text-[10px] font-black tracking-widest uppercase bg-slate-900 text-slate-300 px-2.5 py-1 rounded-md border border-slate-700">
                  {post.data.colorVariety}
                </span>
                {post.data.hasRevenueStamps && (
                  <span class="text-[10px] font-black tracking-widest uppercase bg-rose-500/20 text-rose-400 px-2.5 py-1 rounded-full border border-rose-500/30 animate-pulse">
                    🍁 Holds Revenue Stamps
                  </span>
                )}
              </div>


              <h2 class="text-2xl font-black text-white tracking-tight mb-1">{post.data.title}</h2>
              <p class="text-xs text-slate-500 font-mono mb-4">
                Issued: {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}{post.data.cancelDate && ` • Cancelled: ${post.data.cancelDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}`} • Serial No: #{post.data.serialNumber} • Registry Entry #{post.data.sequence}
              </p>

              <!-- Markdown Typography Content Box -->
              <div class="prose prose-invert prose-slate max-w-none text-slate-300 text-sm border-t border-slate-700/60 pt-4
                prose-p:text-slate-400 prose-p:leading-relaxed prose-p:mb-3
                prose-strong:text-amber-400 prose-strong:font-bold">
                <Content />
              </div>
            </div>
          </div>

          <!-- RIGHT IMAGE FRAME PANEL: 2-Column Side-by-Side Symmetrical Matrix -->
          <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-4">
            
            <!-- Front Face Side Canvas -->
            <div class="flex flex-col justify-between">
              <div class="bg-slate-900 border border-slate-700 p-2.5 rounded-xl aspect-[1.4/1] flex items-center justify-center shadow-inner group hover:border-amber-500/50 transition-colors duration-150">
                {frontSrc ? (
                  <a href={frontSrc} data-pswp-width={frontW} data-pswp-height={frontH} target="_blank" title="View Full-Size Certificate Face" class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in">
                    <img src={frontSrc} alt={`${post.data.title} Front View`} class="max-w-full max-h-full object-contain filter drop-shadow-md group-hover:scale-[1.01] transition-transform duration-150" />
                  </a>
                ) : (
                  <div class="text-xs text-rose-500 font-mono">Front Panel Image Missing</div>
                )}
              </div>
              <p class="text-[9px] font-bold text-center text-slate-500 mt-2 tracking-widest uppercase">Certificate Face</p>
            </div>

            <!-- Back Reverse Side Canvas -->
            <div class="flex flex-col justify-between">
              <div class="bg-slate-900 border border-slate-700 p-2.5 rounded-xl aspect-[1.4/1] flex items-center justify-center shadow-inner group hover:border-amber-500/50 transition-colors duration-150">
                {backSrc ? (
                  <a href={backSrc} data-pswp-width={backW} data-pswp-height={backH} target="_blank" title="View Full-Size Reverse Transfer" class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in">
                    <img src={backSrc} alt={`${post.data.title} Reverse View`} class="max-w-full max-h-full object-contain filter drop-shadow-md group-hover:scale-[1.01] transition-transform duration-150" />
                  </a>
                ) : (
                  <div class="text-xs text-slate-600 font-mono italic">Reverse/Back Side Missing</div>
                )}
              </div>
              <p class="text-[9px] font-bold text-center text-slate-500 mt-2 tracking-widest uppercase">Reverse Backing</p>
            </div>

          </div>

        </article>
      ))}
    </div>

  </main>
</Layout>

<!-- PhotoSwipe Local Bundle Injection Engine -->
<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#stocks-archive-grid',
    children: 'a.lightbox-trigger',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.96,
    padding: { top: 30, bottom: 30, left: 30, right: 30 }
  });

  lightbox.on('uiRegister', function() {
    lightbox.pswp.ui.registerElement({
      name: 'download-button',
      order: 8,
      isButton: true,
      tagName: 'a',
      html: '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 32 32" width="24" height="24"><path d="M23 14l-7 7-7-7h4V4h6v10h4zM4 26h24v2H4v-2z" fill="currentColor"/></svg>',
      onInit: (el, pswp) => {
        el.setAttribute('download', '');
        el.setAttribute('target', '_blank');
        el.setAttribute('title', 'Download Certificate Document');
        pswp.on('change', () => {
          el.href = pswp.currSlide.data.src;
        });
      }
    });
  });

  lightbox.init();
</script>
